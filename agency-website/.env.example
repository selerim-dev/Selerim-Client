# Copy this file to .env.local for local development.
# In Vercel, add the same variables in Project Settings -> Environment Variables.

NEXT_PUBLIC_WEB3FORMS_ACCESS_KEY=replace_with_your_web3forms_access_key

# --- AI strategy generator (homepage hero) ---
# Set ONE of the following to enable real AI responses. With neither set, the
# homepage runs in demo mode using a built-in mock strategy.

# Option A (recommended): Vercel AI Gateway key.
# Create one in the Vercel dashboard under AI Gateway. Routes to Claude and others.
AI_GATEWAY_API_KEY=

# Option B: a direct Anthropic API key (from console.anthropic.com).
ANTHROPIC_API_KEY=

# Optional: override the model.
# Defaults to claude-haiku-4-5 (Anthropic) or anthropic/claude-haiku-4-5 (Gateway).
AI_MODEL=
