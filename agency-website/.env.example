# Copy this file to .env.local for local development.
# In Vercel, add the same variables in Project Settings -> Environment Variables.

NEXT_PUBLIC_WEB3FORMS_ACCESS_KEY=replace_with_your_web3forms_access_key

# --- AI strategy generator (homepage hero) ---
# Set ONE of the following to enable real AI responses. With neither set, the
# homepage runs in demo mode using a built-in mock strategy.

# Option A: a direct provider key (e.g. OpenAI, from platform.openai.com).
AI_API_KEY=

# Option B (alternative): a Vercel AI Gateway key (Vercel dashboard -> AI Gateway).
AI_GATEWAY_API_KEY=

# Optional: override the model. Defaults to gpt-4o-mini (direct) or
# openai/gpt-4o-mini (Gateway).
AI_MODEL=

# --- Rate limiting (optional, for durable/distributed limits) ---
# The strategy endpoint is rate-limited per IP. Without these, an in-memory
# limiter is used (per serverless instance). For durable limits across all
# instances, provision Upstash Redis (Vercel Marketplace) and set:
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
